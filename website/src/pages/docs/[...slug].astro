---
import Base from "../../layouts/Base.astro"
import DocsSidebar from "../../components/DocsSidebar.astro"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const allDocs = await getCollection("docs")
  return allDocs
    .filter((doc) => doc.id !== "README")
    .map((doc) => {
      const slug = doc.id.replace(/^\d+-/, "").replace(/\/\d+-/g, "/")
      return { params: { slug }, props: { doc } }
    })
}

const { doc } = Astro.props
const { Content } = await render(doc)

function extractTitle(body: string): string {
  const match = body.match(/^#\s+(.+)$/m)
  return match ? match[1] : "Untitled"
}

function slugToSection(id: string): string | undefined {
  if (id.includes("features/")) return "Features"
  if (id.includes("reference/")) return "Reference"
  return undefined
}

const allDocs = await getCollection("docs")
const pages = allDocs
  .filter((d) => d.id !== "README")
  .map((d) => ({
    slug: d.id.replace(/^\d+-/, "").replace(/\/\d+-/g, "/"),
    title: extractTitle(d.body || ""),
    section: slugToSection(d.id),
  }))

const currentSlug = doc.id.replace(/^\d+-/, "").replace(/\/\d+-/g, "/")
const title = extractTitle(doc.body || "")
---

<Base title={`${title} — Shannon`}>
  <div class="flex gap-8">
    <aside class="w-48 shrink-0 hidden md:block">
      <DocsSidebar pages={pages} currentSlug={currentSlug} />
    </aside>
    <article class="prose-shannon min-w-0 flex-1">
      <Content />
    </article>
  </div>
</Base>
