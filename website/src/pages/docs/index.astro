---
import Base from "../../layouts/Base.astro"
import { getCollection } from "astro:content"

const allDocs = await getCollection("docs")

// Build page list with titles and sections
function extractTitle(body: string): string {
  const match = body.match(/^#\s+(.+)$/m)
  return match ? match[1] : "Untitled"
}

function slugToSection(id: string): string | undefined {
  if (id.includes("features/")) return "Features"
  if (id.includes("reference/")) return "Reference"
  return undefined
}

const pages = allDocs
  .filter((doc) => doc.id !== "README")
  .map((doc) => ({
    slug: doc.id.replace(/^\d+-/, "").replace(/\/\d+-/g, "/"),
    title: extractTitle(doc.body || ""),
    section: slugToSection(doc.id),
  }))
---

<Base title="Shannon — Documentation">
  <div class="prose-shannon">
    <h1>Documentation</h1>
    <p>
      Shannon is a poly-shell built on nushell, with bash compatibility via
      brush. Press Shift+Tab to switch between nushell and bash.
    </p>

    <h2>Guides</h2>
    <ul>
      {
        pages
          .filter((p) => !p.section)
          .map((p) => (
            <li>
              <a href={`/docs/${p.slug}`}>{p.title}</a>
            </li>
          ))
      }
    </ul>

    {
      ["Features", "Reference"].map((section) => {
        const items = pages.filter((p) => p.section === section)
        return items.length > 0 ? (
          <>
            <h2>{section}</h2>
            <ul>
              {items.map((p) => (
                <li>
                  <a href={`/docs/${p.slug}`}>{p.title}</a>
                </li>
              ))}
            </ul>
          </>
        ) : null
      })
    }

    <h2>Nushell Documentation</h2>
    <p>
      Shannon IS nushell — all nushell features work natively. For
      nushell-specific topics, see the{" "}
      <a href="https://nushell.sh/book/">Nushell documentation</a>.
    </p>
  </div>
</Base>
