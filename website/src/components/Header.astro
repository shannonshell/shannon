---
interface Props {
  showBrand?: boolean
}
const { showBrand = true } = Astro.props
---

<header class="flex items-center gap-4 text-sm">
  {showBrand && (
    <a href="/" class="flex items-center gap-2 text-foreground hover:text-primary font-bold">
      <img src="/images/shannon-1.webp" alt="Shannon logo" class="w-5 h-5" />
      Shannon
    </a>
  )}
  <nav class="flex gap-3 text-muted">
    <a href="/docs" class="hover:text-accent">Docs</a>
    <a href="https://github.com/shannonshell/shannon" class="hover:text-accent">GitHub</a>
  </nav>
</header>
