---
interface Props {
  showBrand?: boolean;
}
const { showBrand = true } = Astro.props;
---

<header class="flex items-center gap-4 text-sm">
  {
    showBrand && (
      <a
        href="/"
        class="text-foreground hover:text-primary flex items-center gap-2 font-bold"
      >
        <picture>
          <source
            srcset="/images/shannon-2-dark.png"
            media="(prefers-color-scheme: dark)"
          />
          <img
            src="/images/shannon-2-light.png"
            alt="Shannon logo"
            class="h-5 w-5"
          />
        </picture>
        Shannon
      </a>
    )
  }
  <nav class="text-muted flex gap-3">
    <a href="/docs" class="hover:text-accent">Docs</a>
    <a href="https://github.com/shannonshell/shannon" class="hover:text-accent"
      >GitHub</a
    >
  </nav>
</header>
